# OpenAI API Key: Required for LangChain, Embeddings (text-embedding-3-small), and ChatOpenAI models used in the summarization pipeline.
OPENAI_API_KEY="sk-..."

# Azure Document Intelligence Endpoint: Required for Phase 2+ file parsing and OCR (extracting text/tables from PDFs, etc). 
AZURE_DI_ENDPOINT="https://<your-resource-name>.cognitiveservices.azure.com/"

# Azure Document Intelligence Key: The authentication key for the Azure DI service.
AZURE_DI_KEY="<your-azure-di-key>"

# PostgreSQL Database URL: Connection string for the database (needs pgvector extension).
DATABASE_URL="postgresql://postgres:password@localhost:5432/omnilog"
REDIS_URL="redis://localhost:6379/0"
